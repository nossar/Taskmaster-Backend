SECRET_KEY=troque-por-uma-chave-gerada-com-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=["*"]

# String de conexão do banco (formato dj-database-url). Deixe vazio para usar SQLite local.
DATABASE_URL=

# E-mail (recuperação de senha). Em dev (DEBUG=True), usa o backend de console (imprime no terminal).
# Em produção (DEBUG=False), usa Resend via django-anymail e exige RESEND_API_KEY.
DEFAULT_FROM_EMAIL=no-reply@taskmaster.local
RESEND_API_KEY=

# URL do frontend (usada para montar o link do e-mail de redefinição de senha)
FRONTEND_URL=http://localhost:5173
